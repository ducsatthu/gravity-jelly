{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "02-foundations/01-jelly-block/**",
              "02-foundations/02-eyes/**",
              "02-foundations/03-icon/**",
              "03-components/01-button/**",
              "03-components/02-hud/**",
              "03-components/03-tray/**",
              "03-components/04-gravity-rotate-button/**",
              "03-components/05-combo-popup/**",
              "03-components/06-dialog/**",
              "03-components/07-jelly-scene/**",
              "03-components/08-objective-bar/**",
              "03-components/09-boss-hud/**",
              "04-screens/**",
              "04-screens/play/**",
              "07-mechanics/**",
              "08-brand/**",
              "board.jsx",
              "game-screen.jsx",
              "jelly-play.jsx",
              "world4-strip.jsx"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Baloo 2|Fredoka|Nunito))/i]",
        "message": "Font not provided by the design system. Available: Baloo 2, Fredoka, Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='BossTell'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|label|countdown|key|ref|className|style|children)$/]",
        "message": "<BossTell> doesn't accept that prop. Declared props: kind, label, countdown."
      },
      {
        "selector": "JSXOpeningElement[name.name='BossTell'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:trash|gravity)$/]",
        "message": "<BossTell> kind must be one of 'trash' | 'gravity'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|fullWidth|disabled|comingSoon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, fullWidth, disabled, comingSoon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComboPopup'] > JSXAttribute > JSXIdentifier[name!=/^(?:combo|praise|pieces|colors|showDish|height|label|visible|animate|style|key|ref|className|style|children)$/]",
        "message": "<ComboPopup> doesn't accept that prop. Declared props: combo, praise, pieces, colors, showDish, height, label, visible, animate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|icon|children|actions|onClose|dismissable|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, title, icon, children, actions, onClose, dismissable, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyes'] > JSXAttribute > JSXIdentifier[name!=/^(?:direction|blockSize|open|expression|style|key|ref|className|style|children)$/]",
        "message": "<Eyes> doesn't accept that prop. Declared props: direction, blockSize, open, expression, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GravityRotateButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:turnsLeft|onRotate|disabled|style|key|ref|className|style|children)$/]",
        "message": "<GravityRotateButton> doesn't accept that prop. Declared props: turnsLeft, onRotate, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hud'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|best|direction|onPause|style|key|ref|className|style|children)$/]",
        "message": "<Hud> doesn't accept that prop. Declared props: score, best, direction, onPause, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='JellyConnect'] > JSXAttribute > JSXIdentifier[name!=/^(?:top|right|bottom|left|key|ref|className|style|children)$/]",
        "message": "<JellyConnect> doesn't accept that prop. Declared props: top, right, bottom, left."
      },
      {
        "selector": "JSXOpeningElement[name.name='JellyScene'] > JSXAttribute > JSXIdentifier[name!=/^(?:showDish|showCast|band|style|key|ref|className|style|children)$/]",
        "message": "<JellyScene> doesn't accept that prop. Declared props: showDish, showCast, band, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TutorialGoal'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|variant|label|current|target|status|key|ref|className|style|children)$/]",
        "message": "<TutorialGoal> doesn't accept that prop. Declared props: kind, variant, label, current, target, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='TutorialGoal'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:tutorial)$/]",
        "message": "<TutorialGoal> kind must be one of 'tutorial'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrayPieceModel'] > JSXAttribute > JSXIdentifier[name!=/^(?:cells|color|count|key|ref|className|style|children)$/]",
        "message": "<TrayPieceModel> doesn't accept that prop. Declared props: cells, color, count."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
