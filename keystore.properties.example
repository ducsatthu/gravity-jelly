# Mẫu cấu hình khoá ký RELEASE cho Google Play.
# Sao chép file này thành `keystore.properties` (KHÔNG commit — đã có trong .gitignore),
# rồi điền giá trị thật. Vắng file thì bản release tự ký bằng debug key (chỉ build thử).
#
# Tạo upload keystore:
#   keytool -genkeypair -v -keystore gravity-jelly-upload.jks \
#           -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile: đường dẫn tới file .jks (tuyệt đối, hoặc tương đối so với thư mục gốc dự án).

storeFile=/duong/dan/tuyet-doi/gravity-jelly-upload.jks
storePassword=DOI_MAT_KHAU_KEYSTORE
keyAlias=upload
keyPassword=DOI_MAT_KHAU_KEY
