<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GravityJelly">

        <!-- AdMob App ID — theo build type: debug = id TEST, release = id THẬT.
             Giá trị đặt ở build.gradle.kts (resValue admob_app_id). -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="@string/admob_app_id" />

        <!-- Firebase Analytics (GA4) + Crashlytics: MẶC ĐỊNH TẮT thu thập (privacy-first).
             AnalyticsManager bật lại SAU khi có đồng thuận UMP (canRequestAds). -->
        <meta-data android:name="firebase_analytics_collection_enabled" android:value="false" />
        <meta-data android:name="firebase_crashlytics_collection_enabled" android:value="false" />
        <meta-data android:name="google_analytics_default_allow_ad_personalization_signals" android:value="false" />

        <!-- Play Games Services — PROJECT ID (số) do Play Console sinh ra. Đã điền id thật
             (xem @string/game_services_project_id). PlayGamesManager vẫn có cơ chế lùi bảng
             nội bộ nếu LEADERBOARD_ID là placeholder / không đăng nhập được → KHÔNG crash. -->
        <meta-data
            android:name="com.google.android.gms.games.APP_ID"
            android:value="@string/game_services_project_id" />

        <!-- Đa ngôn ngữ (per-app language): AppCompatDelegate.setApplicationLocales tự LƯU và
             KHÔI PHỤC lựa chọn ngôn ngữ qua service này (autoStoreLocales) trên mọi API ≥ 24. -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden|locale|layoutDirection"
            android:theme="@style/Theme.GravityJelly.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
