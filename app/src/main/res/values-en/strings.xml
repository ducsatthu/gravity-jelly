    <!-- ── Handbook — guide entries (title/desc/body markup) ────────────────── -->
    <string name="guide_combo_refill_title">Combo refills spins</string>
    <string name="guide_combo_refill_desc">Combo ×2 or more → +1 spin (longer combos refill more)</string>
    <string name="guide_combo_refill_body">Clear a [p]combo ×2[/p] or more\nto earn [g]+1 spin[/g].\nThe longer the combo,\nthe more spins you get!</string>

    <string name="guide_clear_line_title">Clear row / column</string>
    <string name="guide_clear_line_desc">Fill 1 row or column → clear + points</string>
    <string name="guide_clear_line_body">Fill a whole [p]ROW or COLUMN[/p]\n(9 cells, any color)\n→ the whole line [g]disappears[/g]\nand scores points.</string>

    <string name="guide_gravity_rotate_title">Rotate gravity</string>
    <string name="guide_gravity_rotate_desc">Turn gravity 90°; D-Pad shows direction, the whole cluster falls</string>
    <string name="guide_gravity_rotate_body">Tap the [g]spin button[/g] to turn\ngravity 90°.\nThe [p]D-Pad[/p] shows the current\ndirection — the whole cluster falls!</string>

    <string name="guide_gravity_drop_title">Gravity fall</string>
    <string name="guide_gravity_drop_desc">Blocks fall, stopping at another block / the floor</string>
    <string name="guide_gravity_drop_body">After a clear, the blocks\nabove [g]FALL DOWN[/g]\n— stopping as soon as they\nhit [p]another block / the floor[/p].</string>

    <string name="guide_sticky_cluster_title">Sticky jelly</string>
    <string name="guide_sticky_cluster_desc">Same-color jellies stick into a cluster; block one cell → the whole cluster stops</string>
    <string name="guide_sticky_cluster_body">Same-[p]COLOR[/p] jellies that touch\nSTICK into one block.\nBlock a single jelly\n→ [g]the whole block stops[/g]!</string>

    <string name="guide_form_super1_title">Royal Jelly</string>
    <string name="guide_form_super1_desc">Fill a row / column / 3×3 in one color → Royal Jelly</string>
    <string name="guide_form_super1_body">Fill 1 row, 1 column,\nor a 3×3 in one [p]COLOR[/p]\n→ create a [g]ROYAL JELLY[/g]\nthat sparkles!</string>

    <string name="guide_form_rainbow_title">Rainbow Jelly</string>
    <string name="guide_form_rainbow_desc">3×3 with all three colors (one per row / column) → Rainbow Jelly</string>
    <string name="guide_form_rainbow_body">Arrange a 3×3 with all [p]THREE COLORS[/p]\n(one color per row/column)\n→ create a [g]RAINBOW JELLY[/g].</string>

    <string name="guide_form_super2_title">Jelly King</string>
    <string name="guide_form_super2_desc">Merge 2 same-color Royal Jellies → Jelly King</string>
    <string name="guide_form_super2_body">Merge two Royal Jellies\nof the [p]SAME COLOR[/p]\n→ upgrade to a [g]JELLY KING[/g],\nmuch stronger!</string>

    <string name="guide_form_rainbow2_title">Rainbow Emperor</string>
    <string name="guide_form_rainbow2_desc">Merge 2 different-color blast blocks → Rainbow Emperor (crowned)</string>
    <string name="guide_form_rainbow2_body">Merge two blast blocks\nof [p]DIFFERENT COLORS[/p]\n→ a [g]RAINBOW EMPEROR[/g]\nwearing a crown!</string>

    <string name="guide_detonate_super1_title">Detonate Royal Jelly</string>
    <string name="guide_detonate_super1_desc">Sweep it into a cleared row / column → wipes every same-color cell</string>
    <string name="guide_detonate_super1_body">Sweep a Royal Jelly into\na cleared row/column\nto detonate it, wiping\n[g]EVERY SAME-COLOR CELL[/g] on the board!</string>

    <string name="guide_detonate_super2_title">Detonate Jelly King</string>
    <string name="guide_detonate_super2_desc">Wipes same color + the whole 5×5 around the center</string>
    <string name="guide_detonate_super2_body">Jelly King detonates:\nwipes the same color\n+ the whole [g]5×5 area[/g]\naround the center!</string>

    <string name="guide_detonate_rainbow1_title">Detonate Rainbow Jelly</string>
    <string name="guide_detonate_rainbow1_desc">Wipes every cell of the colors ADJACENT to it</string>
    <string name="guide_detonate_rainbow1_body">Rainbow Jelly detonates:\nwipes every cell of the\n[g]colors NEXT to it[/g].</string>

    <string name="guide_detonate_rainbow2_title">Detonate Rainbow Emperor</string>
    <string name="guide_detonate_rainbow2_desc">Ultimate skill: clears the WHOLE board (even stones)</string>
    <string name="guide_detonate_rainbow2_body">Ultimate skill:\nthe Rainbow Emperor detonates\n→ [g]CLEARS THE WHOLE BOARD[/g]\n(even stones)!</string>

    <string name="guide_water_flow_title">Water Flow</string>
    <string name="guide_water_flow_desc">The top source flows down, grows one tile each turn; blocked it turns and branches all the way down</string>
    <string name="guide_water_drift_title">Ride the current</string>
    <string name="guide_water_drift_desc">A block on the water drifts along the flow each turn and is not pulled out by gravity</string>
    <string name="guide_water_drift_body">A block on the [g]WATER FLOW[/g]\n[p]DRIFTS[/p] downstream each turn —\nfollowing every bend.\n\nA block in the flow [w]WILL NOT FALL[/w]\nunder gravity: the current holds\nit, it cannot drop out of the flow.</string>
    <string name="guide_water_break_title">Break the source</string>
    <string name="guide_water_break_desc">Put an Aqua Jelly (blue) in the row/column through the source, then clear that line to break it</string>
    <string name="guide_water_break_body">Only an [g]AQUA JELLY[/g] (blue)\nstays on the [w]SOURCE[/w] tile\n(other colors drift away).\n\nClear a row/column through the\nsource that [p]HAS an Aqua Jelly[/p]\n→ [s]source dries[/s]; the flow dies.</string>
    <string name="guide_water_flow_body">The [g]WATER SOURCE[/g] on top\nflows [p]DOWN[/p], growing [p]1 TILE[/p]\neach turn.\n\nBlocked, it [p]TURNS SIDE[/p] and can\n[p]BRANCH[/p] — flowing on without\nstopping all the way to the bottom.</string>
    <string name="guide_vine_intro_title">Vines spread</string>
    <string name="guide_vine_intro_desc">Each turn every root grows 1 segment; roots grow 3 ways, stems all 4, up to 4 tips</string>
    <string name="guide_vine_intro_body">Each turn, every root grows just\n[g]1 SEGMENT[/g] at one tip:\n\n• ROOTS grow [p]3 ways[/p] (up, left,\n  right — never with gravity)\n• Stems/tips grow [p]all 4 ways[/p]\n• Each root up to [w]4 TIPS[/w]\n\nBranches grow [s]SEPARATELY[/s],\nnever sticking together.</string>

    <string name="guide_vine_destroy_title">How to destroy vines</string>
    <string name="guide_vine_destroy_desc">Roots are the target; clear a row/column through a root with ≥1 green block to destroy it</string>
    <string name="guide_vine_destroy_body">The ROOT is the [s]TARGET[/s] to break.\nClear a row/column with the root:\n\n• With ≥1 [s]GREEN[/s] block\n  → root + whole vine [g]DISAPPEAR[/g]\n\n• [w]NO[/w] green block\n  → only score points,\n  the root [w]SURVIVES[/w]!</string>

    <string name="guide_vine_sticky_title">Vines stay put</string>
    <string name="guide_vine_sticky_desc">Vines and trash do NOT fall or rotate with gravity — they stay put</string>
    <string name="guide_vine_sticky_body">Vines and trash [s]STAY PUT[/s] —\nthey don\'t fall or drift when you\nrotate [g]GRAVITY[/g].\n\nEvery other block falls around them;\nthe vine stands like a planted root.</string>

    <string name="guide_vine_to_trash_title">Forest trash</string>
    <string name="guide_vine_to_trash_desc">Cut segments wither then die into trash; after a cut the vine pauses growing 1 turn</string>
    <string name="guide_vine_to_trash_body">Cut a vine without [w]breaking the root[/w]\n→ the loose segment disconnects, [g]WITHERS[/g]\n(counting down) then becomes [g]DEAD TRASH[/g].\n\nAfter a cut, the vine [s]PAUSES[/s] growing\nthat turn — a breather!</string>

    <string name="guide_trash_destroy_title">How to clear forest trash</string>
    <string name="guide_trash_destroy_desc">Withering trash still clears by filling a line; dead trash needs a blast block</string>
    <string name="guide_trash_destroy_body">• Trash still [s]WITHERING[/s] (counting\n  down) → still counts for a full line,\n  fill the row/column to clear it.\n\n• [w]DEAD[/w] trash → [w]BLOCKS[/w] the line\n  from filling; only a [p]BLAST BLOCK[/p]\n  (Royal Jelly or higher)\n  can destroy it.</string>

    <!-- ── Handbook: Bosses (end of each world) ──────────────────────────────── -->
    <string name="guide_boss_basic_title">Bosses &amp; Shields</string>
    <string name="guide_boss_basic_desc">Each world ends with a Boss guarded by a Shield — chain combos to break it</string>
    <string name="guide_boss_basic_body">Levels [w]×10[/w] (10 · 20 · 30) are [w]BOSSES[/w].\nA boss has a [g]SHIELD[/g] instead of the usual goal.\n\nEach time your combo hits a [p]NEW tier ≥ ×2[/p]\n→ you break [g]tier − 1 Shield[/g]\n(×2 = 1 · ×3 = 2 · ×4 = 3).\nShield to 0 → [s]boss down[/s]!\n\nEvery boss has its own move —\nwatch the warning chip on the card.</string>

    <string name="guide_boss_worm_title">Meadow Worm</string>
    <string name="guide_boss_worm_desc">World 1 boss — break 5 Shields with combos, no special move</string>
    <string name="guide_boss_worm_body">[w]LEVEL 10[/w] · World 1.\nGentle boss: [g]5 Shields[/g], no moves.\n\nTwo [w]stone blocks[/w] split the board so\nyou can set up multi-line clears.\nKeep chaining [p]combo ≥ ×2[/p]\n→ break the Shield, [s]boss down[/s].</string>

    <string name="guide_boss_forest_title">Forest Spirit</string>
    <string name="guide_boss_forest_desc">World 2 boss — 8 Shields; every 4 turns it grows a new vine root</string>
    <string name="guide_boss_forest_body">[w]LEVEL 20[/w] · World 2.\n[g]8 Shields[/g]. Every [w]4 turns[/w] the Forest\nSpirit [w]grows a new vine root[/w] (“Vine” chip).\n\nCut vines with [s]MINT[/s] blocks to keep\nthe board open, then chain [p]combo ≥ ×2[/p]\nto break Shields before the vines take over.</string>

    <string name="guide_boss_water_title">Waterfall Spirit</string>
    <string name="guide_boss_water_desc">World 3 boss — combo to break the Shield (11); water shoves blocks to disrupt combos</string>
    <string name="guide_boss_water_body">[w]LEVEL 30[/w] · World 3.\nBuild a [g]combo ≥×2[/g] to break the [g]Shield (11)[/g].\n\nWater is a [w]hazard[/w]: the current shoves blocks,\ndisrupting your combos. Every [w]3 turns[/w] the boss\n[w]revives sources[/w] and [w]adds a new one[/w] (max 4).\nDrop an [p]Aqua Jelly[/p] (blue block) to clear a line\nover a source to [w]briefly quench[/w] it, easing pressure.</string>

