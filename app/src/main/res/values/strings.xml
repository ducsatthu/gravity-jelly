    <string name="guide_form_rainbow2_title">Hoàng Đế Cầu Vồng</string>
    <string name="guide_form_rainbow2_desc">Ghép 2 khối giải phóng khác màu → Hoàng Đế Cầu Vồng (đội vương miện)</string>
    <string name="guide_form_rainbow2_body">Ghép hai khối giải phóng\n[p]KHÁC MÀU[/p] dính nhau\n→ [g]HOÀNG ĐẾ CẦU VỒNG[/g]\nđội vương miện!</string>

    <string name="guide_detonate_super1_title">Giải phóng Thạch Hoàng Gia</string>
    <string name="guide_detonate_super1_desc">Cuốn vào hàng / cột bị xóa → quét sạch mọi ô cùng màu</string>
    <string name="guide_detonate_super1_body">Cuốn Thạch Hoàng Gia vào\nmột hàng/cột bị xóa\nsẽ giải phóng, quét sạch\n[g]MỌI Ô CÙNG MÀU[/g] trên bàn!</string>

    <string name="guide_detonate_super2_title">Giải phóng Vua Thạch</string>
    <string name="guide_detonate_super2_desc">Quét cùng màu + cả vùng 5×5 quanh tâm</string>
    <string name="guide_detonate_super2_body">Vua Thạch giải phóng:\nquét sạch cùng màu\n+ cả [g]vùng 5×5[/g]\nquanh tâm!</string>

    <string name="guide_detonate_rainbow1_title">Giải phóng Thạch Cầu Vồng</string>
    <string name="guide_detonate_rainbow1_desc">Quét sạch mọi ô thuộc các màu đang KỀ nó</string>
    <string name="guide_detonate_rainbow1_body">Thạch Cầu Vồng giải phóng:\nquét sạch mọi ô thuộc\n[g]các MÀU đang KỀ[/g] nó.</string>

    <string name="guide_detonate_rainbow2_title">Giải phóng Hoàng Đế Cầu Vồng</string>
    <string name="guide_detonate_rainbow2_desc">Kỹ năng tối thượng: xóa sạch TOÀN BÀN (kể cả đá)</string>
    <string name="guide_detonate_rainbow2_body">Kỹ năng tối thượng:\nHoàng Đế Cầu Vồng giải phóng\n→ [g]XÓA SẠCH TOÀN BÀN[/g]\n(kể cả đá)!</string>

    <string name="guide_water_flow_title">Dòng chảy nước</string>
    <string name="guide_water_flow_desc">Nguồn ở trên cùng chảy xuống, mỗi lượt mọc 1 ô; gặp cản thì rẽ ngang và tách nhánh tới đáy</string>
    <string name="guide_water_flow_body">[g]NGUỒN NƯỚC[/g] ở trên cùng\nchảy [p]XUỐNG[/p], mỗi lượt mọc\nthêm [p]1 Ô[/p].\n\nGặp vật cản thì [p]RẼ NGANG[/p] và\ncó thể [p]TÁCH NHÁNH[/p] — chảy tiếp\nkhông ngừng cho tới đáy bàn.</string>
    <string name="guide_water_drift_title">Trôi theo dòng</string>
    <string name="guide_water_drift_desc">Khối đặt trên dòng nước trôi xuôi theo dòng mỗi lượt và không rơi theo trọng lực</string>
    <string name="guide_water_drift_body">Khối đặt trên [g]DÒNG NƯỚC[/g]\nsẽ [p]TRÔI[/p] xuôi theo dòng mỗi\nlượt — theo cả khúc rẽ.\n\nKhối trong dòng [w]KHÔNG RƠI[/w]\ntheo trọng lực: bị dòng giữ,\nkhông rớt ra khỏi dòng nước.</string>
    <string name="guide_water_break_title">Phá nguồn</string>
    <string name="guide_water_break_desc">Cắm Thạch Nước (khối xanh) vào cột/hàng đi qua ô nguồn rồi xoá dòng đó để phá nguồn</string>
    <string name="guide_water_break_body">Chỉ [g]THẠCH NƯỚC[/g] (khối xanh)\nmới đứng yên trên [w]Ô NGUỒN[/w]\n(màu khác sẽ trôi đi).\n\nXoá hàng/cột đi qua ô nguồn mà\ndòng đó [p]CÓ Thạch Nước[/p]\n→ [s]nguồn khô[/s], cả dòng chảy tắt.</string>
    <string name="guide_vine_intro_title">Dây leo mọc lan</string>
    <string name="guide_vine_intro_desc">Mỗi lượt mỗi gốc mọc thêm 1 đốt; gốc mọc 3 hướng, thân mọc đủ 4 hướng, tối đa 4 ngọn</string>
    <string name="guide_vine_intro_body">Mỗi lượt, mỗi gốc chỉ mọc thêm\n[g]1 ĐỐT[/g] ở một ngọn:\n\n• GỐC mọc [p]3 hướng[/p] (lên, trái,\n  phải — không xuôi trọng lực)\n• Thân/ngọn mọc [p]đủ 4 hướng[/p]\n• Mỗi gốc tối đa [w]4 NGỌN[/w]\n\nCác nhánh mọc [s]RIÊNG BIỆT[/s],\nkhông bao giờ dính vào nhau.</string>

    <string name="guide_vine_destroy_title">Cách phá dây leo</string>
    <string name="guide_vine_destroy_desc">Gốc là mục tiêu; xóa hàng/cột qua gốc có ≥1 khối xanh lá mới phá được</string>
    <string name="guide_vine_destroy_body">GỐC là [s]MỤC TIÊU[/s] cần phá.\nXóa hàng/cột chứa gốc:\n\n• Có ≥1 khối [s]XANH LÁ[/s]\n  → gốc + cả dây [g]BIẾN MẤT[/g]\n\n• [w]KHÔNG[/w] có xanh lá\n  → chỉ ăn điểm,\n  gốc [w]SỐNG SÓT[/w]!</string>

    <string name="guide_vine_sticky_title">Dây leo bám cứng</string>
    <string name="guide_vine_sticky_desc">Dây leo và rác KHÔNG rơi hay xoay theo trọng lực — bám cứng tại chỗ</string>
    <string name="guide_vine_sticky_body">Dây leo và rác [s]BÁM CỨNG[/s] —\nkhông rơi, không trôi khi bạn\nxoay [g]TRỌNG LỰC[/g].\n\nMọi khối khác đổ quanh chúng;\ndây đứng yên như rễ cắm đất.</string>

    <string name="guide_vine_to_trash_title">Rác rừng</string>
    <string name="guide_vine_to_trash_desc">Đốt cắt rời gốc héo dần rồi thành rác chết; cắt xong dây tạm ngưng mọc 1 lượt</string>
    <string name="guide_vine_to_trash_body">Cắt dây mà [w]KHÔNG phá gốc[/w]\n→ đốt rời mất kết nối, [g]HÉO DẦN[/g]\n(đếm ngược) rồi thành [g]RÁC CHẾT[/g].\n\nCắt xong, dây [s]TẠM NGƯNG[/s] mọc\nđúng lượt đó — kịp thở!</string>

    <string name="guide_trash_destroy_title">Cách phá rác rừng</string>
    <string name="guide_trash_destroy_desc">Rác còn héo vẫn xoá được bằng lấp đầy hàng; rác chết chỉ khối giải phóng mới phá</string>
    <string name="guide_trash_destroy_body">• Rác còn [s]HÉO[/s] (đang đếm\n  ngược) → vẫn tính đầy hàng,\n  lấp đầy hàng/cột là xoá.\n\n• Rác [w]CHẾT[/w] → [w]CHẶN[/w] không cho\n  hàng đầy; chỉ [p]KHỐI GIẢI PHÓNG[/p]\n  (Thạch Hoàng Gia trở lên)\n  mới phá được.</string>

    <!-- ── Cẩm nang: Đấu trùm (cuối mỗi thế giới) ────────────────────────────── -->
    <string name="guide_boss_basic_title">Đấu trùm &amp; Khiên</string>
    <string name="guide_boss_basic_desc">Cuối mỗi thế giới là một Đấu trùm có lớp Khiên — lên combo để phá</string>
    <string name="guide_boss_basic_body">Màn [w]×10[/w] (10 · 20 · 30) là [w]ĐẤU TRÙM[/w].\nTrùm có [g]KHIÊN[/g] thay cho mục tiêu thường.\n\nMỗi lần combo chạm mức [p]MỚI ≥ ×2[/p]\n→ phá [g]bậc − 1 Khiên[/g]\n(×2 = 1 · ×3 = 2 · ×4 = 3).\nKhiên về 0 → [s]hạ trùm[/s]!\n\nMỗi trùm có chiêu riêng —\nxem chip cảnh báo trên thẻ.</string>

    <string name="guide_boss_worm_title">Chú Sâu Đồng Cỏ</string>
    <string name="guide_boss_worm_desc">Trùm Thế giới 1 — phá 5 Khiên bằng combo, không có chiêu phụ</string>
    <string name="guide_boss_worm_body">[w]MÀN 10[/w] · Thế giới 1.\nTrùm hiền: [g]5 Khiên[/g], không ra chiêu.\n\nHai [w]đá cản[/w] chia đôi bàn để bạn\ndựng thế xoá nhiều dòng một lúc.\nLên [p]combo ≥ ×2[/p] liên tục\n→ phá Khiên, [s]hạ trùm[/s].</string>

    <string name="guide_boss_forest_title">Thần Rừng</string>
    <string name="guide_boss_forest_desc">Trùm Thế giới 2 — 8 Khiên, cứ 4 lượt lại mọc thêm một gốc dây leo</string>
    <string name="guide_boss_forest_body">[w]MÀN 20[/w] · Thế giới 2.\n[g]8 Khiên[/g]. Mỗi [w]4 lượt[/w] Thần Rừng\n[w]mọc thêm 1 gốc dây[/w] (chip “Mọc dây”).\n\nChặt dây bằng khối [s]MINT[/s] cho bàn\nthoáng, rồi lên [p]combo ≥ ×2[/p] phá\nKhiên trước khi dây phủ kín bàn.</string>

    <string name="guide_boss_water_title">Thần Thác</string>
    <string name="guide_boss_water_desc">Trùm Thế giới 3 — combo phá Khiên (11); nước đẩy khối làm rối combo</string>
    <string name="guide_boss_water_body">[w]MÀN 30[/w] · Thế giới 3.\nDựng [g]combo ≥×2[/g] để phá [g]Khiên (11)[/g].\n\nNước là [w]chướng ngại[/w]: dòng chảy đẩy khối,\nlàm rối thế combo. Mỗi [w]3 lượt[/w] trùm\n[w]hồi sinh nguồn[/w] và [w]thả thêm nguồn[/w] (tối đa 4).\nCắm [p]Thạch Nước[/p] (khối xanh) xoá dòng qua\nô nguồn để [w]tạm dập[/w] một nguồn, giảm áp lực.</string>

