# --- Vercel deploy configuration ---
# Copy this file to ".env" and fill in the values, then run ./deploy.sh

# REQUIRED. Personal access token for non-interactive deploys.
# Create at: https://vercel.com/account/tokens
VERCEL_TOKEN=

# OPTIONAL. Link to an existing Vercel project without prompts (CI style).
# Leave both blank on the FIRST deploy — the CLI creates a new project named
# after this folder. After the first deploy you can read the generated IDs from
# .vercel/project.json and paste them here for deterministic re-deploys.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# OPTIONAL. Team/account slug when the token has no default scope.
VERCEL_SCOPE=
